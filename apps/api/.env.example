# API service
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sdp_200

# Cloudflare R2
R2_ACCOUNT_ID=local-account-id
R2_ACCESS_KEY_ID=local-access-key-id
R2_SECRET_ACCESS_KEY=local-secret-access-key
R2_BUCKET_NAME=sdp-200-local
R2_PUBLIC_BASE_URL=https://example.r2.dev

# OpenRouter
OPENROUTER_API_KEY=local-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Auth/session
JWT_SECRET_KEY=replace-with-a-long-random-string
SESSION_SECRET_KEY=replace-with-a-second-long-random-string
